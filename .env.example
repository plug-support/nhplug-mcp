# NH투자증권 Open API 인증 정보 (포털에서 발급: https://www.nhplug.com/intro)
# 이 파일을 복사해 ".env" 로 만들고 실제 값을 채우세요. .env 는 절대 git 에 커밋하지 마세요.

# 발급받은 앱키 / 앱시크릿
NHPLUG_APP_KEY=여기에_APP_KEY
NHPLUG_APP_SECRET=여기에_APP_SECRET

# 호출 대상 REST Base URL
#   🔴 운영 (Live)    : https://api.nhplug.com:8443   [기본, 실제 주문 체결]
#   🟢 모의투자 (Mock) : https://moapi.nhplug.com:8443  (교육이수·시뮬레이션 테스트)
NHPLUG_BASE_URL=https://api.nhplug.com:8443

# 접근토큰(/oauth2/token)은 운영(api) 전용 — 모의투자엔 없습니다.
# 호출을 moapi 로 하더라도 토큰은 항상 api 에서 발급되므로 아래 기본값을 유지하세요.
NHPLUG_AUTH_URL=https://api.nhplug.com:8443

# ── 브랜드(도메인): 나무(Namuh)=nhplug.com / N2=n2plug.com. API·필드 동일, 도메인만 다름.
#    N2 고객은 위 BASE_URL·AUTH_URL 을 둘 다 n2plug 로 바꾸세요(AUTH 도 필수!).
#      N2 예)  NHPLUG_BASE_URL=https://api.n2plug.com:8443   (개발은 https://moapi.n2plug.com:8443)
#              NHPLUG_AUTH_URL=https://api.n2plug.com:8443

# 주문(매수/매도/정정/취소) 도구 활성화 여부.
# 미설정 또는 false 이면 조회·시세만 제공하며 주문 도구는 완전히 숨겨집니다(안전 기본값).
# 실제 주문을 Claude 로 실행하려면 위험을 이해한 뒤에만 true 로 설정하세요.
NHPLUG_ENABLE_TRADING=false

# (선택) 기본 계좌번호 — 잔고/주문 단축 도구에서 생략 시 사용
NHPLUG_DEFAULT_ACCOUNT=
